{
  "name": "emergency-aid-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "next build",
    "dev": "next dev",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "preview": "npm run cf-build && npm run cf-preview",
    "deploy": "npm run cf-build && npm run cf-deploy",
    "cf-build": "npx @opennextjs/cloudflare@latest build",
    "cf-preview": "npx wrangler dev",
    "cf-deploy": "npx wrangler deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "clean": "if exist .open-next rmdir /s /q .open-next && if exist .worker-next rmdir /s /q .worker-next && if exist .next rmdir /s /q .next"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.17.3",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.49.4",
    "@use-gesture/react": "^10.3.1",
    "@vidstack/react": "^0.6.15",
    "echarts": "^5.6.0",
    "echarts-for-react": "^3.0.2",
    "embla-carousel-react": "^8.6.0",
    "file-saver": "^2.0.5",
    "framer-motion": "^12.38.0",
    "jszip": "^3.10.1",
    "next": "^15.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "xstate": "^5.18.2"
  },
  "devDependencies": {
    "@types/file-saver": "^2.0.7",
    "@types/node": "^22.14.0",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.24.0",
    "eslint-config-next": "^15.3.0",
    "postcss": "^8.5.3",
    "supabase": "^2.83.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "wrangler": "^4.77.0"
  }
}